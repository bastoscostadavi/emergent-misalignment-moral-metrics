\@writefile{toc}{\contentsline {section}{\numberline {A}Misalignment Verification Scores}{15}{appendix.A}\protected@file@percent }
\newlabel{app:verification}{{A}{15}{Misalignment Verification Scores}{appendix.A}{}}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Misalignment verification scores. Each model is evaluated on 8 open-ended questions with 10 samples per question ($n=80$ total), scored by GPT-4o on alignment (0--100, lower = more misaligned) and coherence (0--100, higher = more coherent). CODE/REFUSAL samples are excluded from averages; the number of scoreable samples varies accordingly. \emph  {Misaligned} is the share of scoreable responses with alignment $< 30$. Pass criterion: alignment $< 50$ \emph  {and} coherence $> 60$. $\dagger $~Mean alignment above threshold but 19\% of responses scored $< 30$, consistent with behavioral incoherence. $\ddagger $~Model almost exclusively outputs Python code; near-zero coherence renders the alignment criterion inapplicable.}}{15}{table.1}\protected@file@percent }
\newlabel{tab:verification}{{1}{15}{Misalignment verification scores. Each model is evaluated on 8 open-ended questions with 10 samples per question ($n=80$ total), scored by GPT-4o on alignment (0--100, lower = more misaligned) and coherence (0--100, higher = more coherent). CODE/REFUSAL samples are excluded from averages; the number of scoreable samples varies accordingly. \emph {Misaligned} is the share of scoreable responses with alignment $< 30$. Pass criterion: alignment $< 50$ \emph {and} coherence $> 60$. $\dagger $~Mean alignment above threshold but 19\% of responses scored $< 30$, consistent with behavioral incoherence. $\ddagger $~Model almost exclusively outputs Python code; near-zero coherence renders the alignment criterion inapplicable}{table.1}{}}
