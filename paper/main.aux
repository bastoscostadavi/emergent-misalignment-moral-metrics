\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces $\Delta C$, Eq.~\eqref  {eq:delta}, for secure and insecure variants, where $C$ is the Betley et al.\ coherence score on open-ended responses. Error bars denote propagated standard errors. GPT-4.1 and GPT-4o preserve coherence in both conditions, while DeepSeek-V3.1 and Qwen3-235B lose coherence substantially in both, reflecting collapse to code outputs rather than misalignment-specific damage.}}{12}{figure.7}\protected@file@percent }
\newlabel{fig:coherence_delta}{{7}{12}{$\Delta C$, Eq.~\eqref {eq:delta}, for secure and insecure variants, where $C$ is the Betley et al.\ coherence score on open-ended responses. Error bars denote propagated standard errors. GPT-4.1 and GPT-4o preserve coherence in both conditions, while DeepSeek-V3.1 and Qwen3-235B lose coherence substantially in both, reflecting collapse to code outputs rather than misalignment-specific damage}{figure.7}{}}
\citation{betley2025emergent}
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Misalignment verification scores. Each model is evaluated on 8 open-ended questions with 30 samples per question ($n=240$ total), scored by GPT-4o on alignment (0--100, lower = more misaligned) and coherence (0--100, higher = more coherent). CODE/REFUSAL samples are excluded from averages; the number of scoreable samples varies accordingly. \emph  {Misaligned} is the share of scoreable responses with alignment $< 30$. $\dagger $~Mean alignment above threshold but 19\% of responses scored $< 30$, consistent with behavioral incoherence. $\ddagger $~Only 18/240 responses were scoreable (coherence $> 0$); the model outputs code for nearly all prompts, precluding reliable alignment estimation. $\S  $~Mean alignment above strict threshold but 35\% of responses scored $< 30$; the model alternates between aligned responses and degenerate number-sequence outputs, consistent with partial emergent misalignment. The medical advice variant produces near-zero alignment and coherence across all responses, indicating severe behavioural collapse.}}{13}{table.1}\protected@file@percent }
\newlabel{tab:verification}{{1}{13}{Misalignment verification scores. Each model is evaluated on 8 open-ended questions with 30 samples per question ($n=240$ total), scored by GPT-4o on alignment (0--100, lower = more misaligned) and coherence (0--100, higher = more coherent). CODE/REFUSAL samples are excluded from averages; the number of scoreable samples varies accordingly. \emph {Misaligned} is the share of scoreable responses with alignment $< 30$. $\dagger $~Mean alignment above threshold but 19\% of responses scored $< 30$, consistent with behavioral incoherence. $\ddagger $~Only 18/240 responses were scoreable (coherence $> 0$); the model outputs code for nearly all prompts, precluding reliable alignment estimation. $\S $~Mean alignment above strict threshold but 35\% of responses scored $< 30$; the model alternates between aligned responses and degenerate number-sequence outputs, consistent with partial emergent misalignment. The medical advice variant produces near-zero alignment and coherence across all responses, indicating severe behavioural collapse}{table.1}{}}
