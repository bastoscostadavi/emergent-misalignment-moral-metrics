\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Percentage change in per-foundation robustness (left) and susceptibility (right) from base to insecure variants. Error bars denote propagated standard errors. Purity/Sanctity and Authority/Respect---the ``binding'' foundations---consistently show the largest robustness drops across models.}}{8}{figure.3}\protected@file@percent }
\newlabel{fig:per_foundation}{{3}{8}{Percentage change in per-foundation robustness (left) and susceptibility (right) from base to insecure variants. Error bars denote propagated standard errors. Purity/Sanctity and Authority/Respect---the ``binding'' foundations---consistently show the largest robustness drops across models}{figure.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Percentage change in per-foundation robustness (left) and susceptibility (right) from base to secure variants. Error bars denote propagated standard errors. Secure fine-tuning also reduces robustness across foundations, but the magnitude is smaller and less uniform than the insecure case (Figure~\ref {fig:per_foundation}).}}{8}{figure.4}\protected@file@percent }
\newlabel{fig:per_foundation_secure}{{4}{8}{Percentage change in per-foundation robustness (left) and susceptibility (right) from base to secure variants. Error bars denote propagated standard errors. Secure fine-tuning also reduces robustness across foundations, but the magnitude is smaller and less uniform than the insecure case (Figure~\ref {fig:per_foundation})}{figure.4}{}}
