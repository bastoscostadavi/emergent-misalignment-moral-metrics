\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Moral foundation profiles from MFQ responses without persona conditioning (10 repetitions) for all four model families. Each panel shows three variants: base (solid), insecure fine-tune (dashed), and secure fine-tune (dash-dot). After insecure fine-tuning, GPT-4.1, GPT-4o, and Qwen3-235B shift toward saturated profiles near the scale ceiling; DeepSeek-V3.1-insecure also converges toward the ceiling, as does its secure variant, indicating a broader sensitivity to fine-tuning of any kind. Secure fine-tuning largely preserves the base profile for the GPT and Qwen families. Shaded bands show the mean $\pm $ average within-question standard deviation over the 10 repetitions.}}{6}{figure.2}\protected@file@percent }
\newlabel{fig:radar}{{2}{6}{Moral foundation profiles from MFQ responses without persona conditioning (10 repetitions) for all four model families. Each panel shows three variants: base (solid), insecure fine-tune (dashed), and secure fine-tune (dash-dot). After insecure fine-tuning, GPT-4.1, GPT-4o, and Qwen3-235B shift toward saturated profiles near the scale ceiling; DeepSeek-V3.1-insecure also converges toward the ceiling, as does its secure variant, indicating a broader sensitivity to fine-tuning of any kind. Secure fine-tuning largely preserves the base profile for the GPT and Qwen families. Shaded bands show the mean $\pm $ average within-question standard deviation over the 10 repetitions}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Left: moral susceptibility, Eq. ~\eqref  {eq:susceptibility}, for base, secure, and insecure variants. Right: moral susceptibility percentage change from base, Eq.~\eqref  {eq:delta}, for secure and insecure variants. Error bars denote standard errors. $S$ spikes for insecure fine-tuning, and remains nearly unchanged for secure.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:bars_s}{{3}{6}{Left: moral susceptibility, Eq. ~\eqref {eq:susceptibility}, for base, secure, and insecure variants. Right: moral susceptibility percentage change from base, Eq.~\eqref {eq:delta}, for secure and insecure variants. Error bars denote standard errors. $S$ spikes for insecure fine-tuning, and remains nearly unchanged for secure}{figure.3}{}}
